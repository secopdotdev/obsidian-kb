---
/**
 * Backlinks.astro — "What links here" panel.
 * Reads src/data/backlinks.json which is generated by scripts/build-backlinks.mjs
 * (prebuild step). Falls back gracefully if the file is absent or the note has
 * no backlinks.
 *
 * CHICKEN-AND-EGG NOTE:
 * backlinks.json is generated at prebuild and is gitignored. A stub empty file
 * is committed at src/data/backlinks.json so that `astro dev` (which skips
 * prebuild) doesn't crash on the import. The stub contains `{}`.
 */
import backlinksData from '../data/backlinks.json';

export interface Props {
  noteId: string;
}

const { noteId } = Astro.props;

// backlinksData is Map-like: { [slug]: string[] }
const data = backlinksData as Record<string, string[]>;
const links: string[] = data[noteId] ?? [];
---

<section class="backlinks" aria-label="Backlinks">
  <p class="backlinks-title">Backlinks</p>
  {links.length === 0
    ? <p class="empty-state">No backlinks</p>
    : (
      <ul>
        {links.map((slug) => (
          <li>
            <a href={`/notes/${slug}`} title={slug}>{slug.split('/').pop()}</a>
          </li>
        ))}
      </ul>
    )
  }
</section>
