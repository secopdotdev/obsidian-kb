---
/**
 * search.astro — Pagefind search page.
 *
 * Uses @pagefind/default-ui for the search UI.
 * Pagefind is initialized via a regular Astro <script> (externalized to /_astro/*.js)
 * to remain CSP-compliant (script-src 'self'; no inline scripts).
 *
 * NOTE: The Pagefind index is built AFTER astro build completes by running
 * `npx pagefind --site dist`. During `npm run dev`, Pagefind search won't return
 * results unless you manually run pagefind against a previous build's dist/ dir.
 *
 * CSP NOTE: Pagefind WASM may require `wasm-unsafe-eval` in script-src on some
 * browser engines. The Traefik Middleware includes it with a comment — verify
 * in-browser via DevTools CSP console before removing it.
 */
import Base from '../layouts/Base.astro';
---

<Base title="Search" description="Search all knowledge base notes">
  <main class="layout-content" data-pagefind-ignore>
    <h1>Search</h1>
    <p style="color:var(--color-text-muted);font-size:0.875rem;margin-bottom:1.5rem;">
      Full-text search across all notes. Use the type and tag filters to narrow results.
    </p>

    <div id="search-container"></div>
  </main>

  <aside class="layout-rail" aria-label="Search tips">
    <p class="section-label">Search Tips</p>
    <ul style="list-style:none;padding:0;font-size:0.8125rem;color:var(--color-text-muted);">
      <li style="margin-bottom:0.5rem;">Filter by <strong>type</strong>: project, adr, cli, error…</li>
      <li style="margin-bottom:0.5rem;">Filter by <strong>tag</strong>: any controlled tag</li>
      <li style="margin-bottom:0.5rem;">Phrase search: <code>"git converge"</code></li>
    </ul>
  </aside>
</Base>

<script>
  // Pagefind initialization — externalized by Astro's build → /_astro/*.js
  // CSP-safe: no inline script content, served from 'self'.
  import { PagefindUI } from '@pagefind/default-ui';

  // Wait for DOM ready.
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('search-container');
    if (!el) return;

    new PagefindUI({
      element: '#search-container',
      // Open type and tag filters by default.
      openFilters: ['type', 'tag'],
      // Pagefind index is at /pagefind/ (generated by npx pagefind --site dist).
      bundlePath: '/pagefind/',
      showImages: false,
      showEmptyFilters: true,
      resetStyles: false,
    });
  });
</script>
